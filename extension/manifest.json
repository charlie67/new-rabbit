{
  "manifest_version": 3,
  "name": "Rabbit Tab Streamer",
  "version": "1.0.0",
  "description": "Captures the controlled tab with tabCapture and publishes it to MediaMTX via WHIP.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": ["tabCapture", "offscreen"],
  "host_permissions": ["http://127.0.0.1:8889/*"],
  "background": {
    "service_worker": "background.js"
  }
}
